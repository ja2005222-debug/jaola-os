import express from 'express';
import { verifyToken } from '../services/auth.js';
import crypto from 'crypto';
import { analyzeUserRequest } from '../agents/reasoning.agent.js';
import { conversationAgent } from '../agents/conversation.agent.js';
import { getDB } from '../services/database.js';

const router = express.Router();

function authMiddleware(req, res, next) {
    const authHeader = req.headers.authorization;
    if (!authHeader) return res.status(401).json({ error: 'No token provided' });
    const token = authHeader.split(' ')[1];
    const decoded = verifyToken(token);
    if (!decoded) return res.status(401).json({ error: 'Invalid token' });
    req.userId = decoded.id;
    next();
}

function getSessionId(bodySessionId) {
    return bodySessionId || crypto.randomUUID();
}

// ... routes for profile, tasks, plans remain the same (omitted for brevity) ...

router.post('/request', authMiddleware, async (req, res) => {
    const { message, sessionId: clientSessionId } = req.body;
    if (!message) return res.status(400).json({ error: 'Message required' });
    
    const sessionId = getSessionId(clientSessionId);
    const userId = req.userId;
    
    // 1. Intent Engine (باستخدام Groq)
    const intentData = await analyzeUserRequest(message);
    console.log(`[Intent] ${message} -> ${intentData.intent} (${intentData.confidence})`);
    
    // 2. إذا كانت الثقة منخفضة، نطلب توضيحاً
    if (intentData.confidence < 0.6) {
        const reply = `لست متأكداً مما إذا كنت تريد أمراً أم سؤالاً. ثقتي ${Math.round(intentData.confidence*100)}%. هل يمكنك توضيح؟`;
        return res.json({ type: 'clarification', reply, sessionId });
    }
    
    // 3. إذا كان محادثة أو سؤال، يرد Conversation Agent مباشرة
    if (intentData.intent === 'chat' || intentData.intent === 'question') {
        const reply = await conversationAgent(message, sessionId, userId);
        return res.json({ type: intentData.intent, reply, sessionId });
    }
    
    // 4. الأوامر والأعمال والنشر: إنشاء خطة
    const { createPlan } = await import('../agents/planner.agent.js');
    const plan = await createPlan(message, []);
    
    if (!plan.tasks || plan.tasks.length === 0) {
        const reply = await conversationAgent(message, sessionId, userId);
        return res.json({ type: 'conversation', reply, sessionId });
    }
    
    const { addPlan, addTask } = await import('../services/taskQueue.js');
    const savedPlan = await addPlan({ goal: plan.goal, tasks: plan.tasks.map(t => t.id), userId });
    for (const task of plan.tasks) {
        await addTask({ ...task, userId });
    }
    return res.json({ 
        success: true, 
        planId: savedPlan.id, 
        tasksCount: plan.tasks.length, 
        type: 'plan',
        intent: intentData.intent,
        subCategory: intentData.subCategory,
        sessionId 
    });
});

export default router;
