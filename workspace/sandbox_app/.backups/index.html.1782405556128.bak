<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.2.1/flowbite.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flowbite/2.2.1/flowbite.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;500;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
    <style>
        * { font-family: 'Tajawal', sans-serif; scroll-behavior: smooth; }
    </style>
    <title>مطعم بيتزا</title>
</head>
<body class="bg-gradient-to-b from-blue-200 to-white text-slate-100 min-h-screen relative overflow-x-hidden">
    <!-- توهج النيون في الخلفية لجمال بصري فخم -->
    <div class="absolute top-[-100px] left-[-100px] w-[400px] h-[400px] rounded-full bg-blue-500/10 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-[-150px] right-[-100px] w-[500px] h-[500px] rounded-full bg-blue-500/10 blur-[150px] pointer-events-none"></div>

    <header class="border-b border-slate-900 bg-blue-100/80 backdrop-blur-md sticky top-0 z-50 px-6 py-4 flex items-center justify-between">
        <div class="text-lg font-extrabold bg-gradient-to-r from-blue-400 to-blue-600 bg-clip-text text-transparent">مطعم بيتزا</div>
        <nav class="hidden md:flex items-center gap-6 text-xs text-slate-400">
            <a href="#menu" class="hover:text-blue-400 transition-colors">قائمة الطعام</a>
            <a href="#about" class="hover:text-blue-400 transition-colors">عن المطعم</a>
            <a href="#contact" class="hover:text-blue-400 transition-colors">اتصل بنا</a>
        </nav>
        <button class="bg-gradient-to-r from-blue-500 to-blue-600 text-white font-bold text-base px-6 py-3 rounded-xl shadow-lg shadow-blue-500/20 hover:scale-[1.02] transition-all">اطلب الآن</button>
    </header>

    <main class="max-w-4xl mx-auto text-center px-6 py-20 flex flex-col items-center justify-center">
        <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-6">مطعم بيتزا <span class="bg-gradient-to-r from-blue-400 to-blue-600 bg-clip-text text-transparent">بيتزا لذيذة</span></h1>
        <p class="text-slate-400 text-sm md:text-base leading-relaxed max-w-xl mb-10">مطعم بيتزا يقدم لكم أشهى أنواع البيتزا في جو ريفي رومانسي.</p>
        <div class="flex items-center gap-4">
            <button class="bg-gradient-to-r from-blue-500 to-blue-600 text-white font-bold text-xs px-6 py-3 rounded-xl shadow-lg shadow-blue-500/20 hover:scale-[1.02] transition-all">استكشف القائمة 🍕</button>
            <button class="border border-slate-800 hover:bg-slate-900 text-xs text-slate-300 font-bold px-6 py-3 rounded-xl transition-all">اطلب الآن</button>
        </div>
    </main>
    <script src="script.js"></script>
</body>
</html>