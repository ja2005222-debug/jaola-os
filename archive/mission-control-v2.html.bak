<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>JAOLA OS | Mission Control</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/diff2html/bundles/css/diff2html.min.css">
    <script src="https://cdn.jsdelivr.net/npm/diff2html/bundles/js/diff2html-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/diff/dist/diff.min.js"></script>
    <style>
        * { font-family: 'Inter', 'Tajawal', sans-serif; }
        body { background: #09090B; color: #e5e7eb; scroll-behavior: smooth; }
        .glass { background: rgba(17, 24, 39, 0.7); backdrop-filter: blur(4px); border: 1px solid #27272A; border-radius: 1.5rem; }
        .glass-panel { background: rgba(17, 24, 39, 0.5); backdrop-filter: blur(2px); border: 1px solid #27272A; }
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: #18181B; border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: #3b82f6; border-radius: 10px; }
        .status-running { animation: pulse 1.5s infinite; }
        @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.6; } }
        .agent-card { transition: all 0.2s ease; border-left: 3px solid transparent; }
        .agent-card:hover { border-left-color: #3b82f6; background: rgba(59,130,246,0.05); }
        .workflow-card { transition: transform 0.1s ease; }
        .workflow-card:hover { transform: translateY(-2px); background: rgba(59,130,246,0.2); }
        iframe { border: none; width: 100%; height: 500px; background: white; border-radius: 1rem; }
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden">

    <div class="flex flex-1 overflow-hidden">
        <!-- SIDEBAR -->
        <aside class="w-80 flex-shrink-0 bg-[#09090B] border-l border-[#27272A] flex flex-col p-5 overflow-y-auto">
            <div class="mb-8">
                <h1 class="text-2xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">JAOLA OS</h1>
                <p class="text-xs text-gray-500">Autonomous Software Engineering Platform</p>
            </div>
            <div class="mb-6">
                <div class="flex justify-between items-center mb-2">
                    <h3 class="text-xs font-semibold text-gray-400 uppercase">PROJECTS</h3>
                    <button id="newProjectBtn" class="text-xs text-blue-400"><i class="fas fa-plus"></i> New</button>
                </div>
                <div id="projectsList" class="space-y-1 max-h-48 overflow-y-auto"></div>
            </div>
            <nav class="mb-6">
                <h3 class="text-xs font-semibold text-gray-400 uppercase mb-2">MENU</h3>
                <div class="space-y-1">
                    <a href="/mission-control-v2.html" class="flex items-center gap-3 p-2 rounded-lg bg-blue-900/30 text-blue-400"><i class="fas fa-tachometer-alt w-5"></i> Mission Control</a>
                    <a href="/agents.html" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-microchip w-5"></i> Agents Center</a>
                    <a href="/architecture.html" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-project-diagram w-5"></i> Architecture</a>
                    <a href="/workflow.html" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-chart-line w-5"></i> Workflow</a>
                    <a href="/projects.html" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-folder-open w-5"></i> Projects</a>
                    <a href="#" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-brain w-5"></i> Decisions</a>
                    <a href="#" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-cog w-5"></i> Settings</a>
                </div>
            </nav>
            <div class="mt-auto pt-4 border-t border-[#27272A] flex justify-between">
                <div class="flex items-center gap-2">
                    <i class="fas fa-user-circle text-2xl text-gray-400"></i>
                    <div><div id="usernameDisplay" class="text-sm font-medium">Developer</div><div class="text-xs text-gray-500">Pro Plan</div></div>
                </div>
                <button id="logoutBtn" class="text-xs text-gray-500 hover:text-white"><i class="fas fa-sign-out-alt"></i></button>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="flex-1 flex flex-col overflow-hidden p-5 gap-5">
            <!-- Hero + Progress Ring -->
            <div class="glass p-5 flex justify-between items-center">
                <div>
                    <div class="text-sm text-gray-400">Active Project</div>
                    <h2 id="activeProjectName" class="text-2xl font-bold">Travel Platform</h2>
                    <div class="flex items-center gap-2 mt-1">
                        <span class="inline-block w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                        <span id="projectStatus" class="text-xs text-green-400">ACTIVE</span>
                    </div>
                </div>
                <div class="relative w-20 h-20">
                    <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                        <circle cx="50" cy="50" r="42" fill="none" stroke="#27272A" stroke-width="6"/>
                        <circle id="progressCircle" cx="50" cy="50" r="42" fill="none" stroke="#3b82f6" stroke-width="6" stroke-linecap="round" stroke-dasharray="263.89" stroke-dashoffset="263.89"/>
                    </svg>
                    <div id="progressPercent" class="absolute inset-0 flex items-center justify-center text-sm font-bold">0%</div>
                </div>
            </div>

            <!-- KPI Cards -->
            <div class="grid grid-cols-5 gap-4">
                <div class="glass-panel p-3 rounded-xl text-center"><div class="text-2xl font-bold" id="kpiProjects">—</div><div class="text-xs text-gray-400">Projects</div></div>
                <div class="glass-panel p-3 rounded-xl text-center"><div class="text-2xl font-bold" id="kpiTasks">—</div><div class="text-xs text-gray-400">Tasks</div></div>
                <div class="glass-panel p-3 rounded-xl text-center"><div class="text-2xl font-bold text-green-400" id="kpiDeployments">—</div><div class="text-xs text-gray-400">Deployments</div></div>
                <div class="glass-panel p-3 rounded-xl text-center"><div class="text-2xl font-bold text-blue-400" id="kpiBuildSuccess">—%</div><div class="text-xs text-gray-400">Build Success</div></div>
                <div class="glass-panel p-3 rounded-xl text-center"><div class="text-2xl font-bold text-purple-400" id="kpiAutoFix">—%</div><div class="text-xs text-gray-400">AutoFix</div></div>
            </div>

            <!-- AI Team Grid -->
            <div id="agentsGrid" class="grid grid-cols-2 gap-4">
                <div class="glass rounded-2xl p-4"><div class="flex justify-between"><span>🧠 Architect</span><span class="text-green-400">●</span></div><div class="text-sm text-zinc-400 mt-2">Designing Auth System</div><div class="mt-3 text-xs">Success: 98%</div></div>
                <div class="glass rounded-2xl p-4"><div class="flex justify-between"><span>📋 Planner</span><span class="text-blue-400">●</span></div><div class="text-sm text-zinc-400 mt-2">Planning Tasks</div><div class="mt-3 text-xs">Success: 96%</div></div>
                <div class="glass rounded-2xl p-4"><div class="flex justify-between"><span>💻 Coder</span><span class="text-green-400">●</span></div><div class="text-sm text-zinc-400 mt-2">Editing app/page.tsx</div><div class="mt-3 text-xs">Success: 97%</div></div>
                <div class="glass rounded-2xl p-4"><div class="flex justify-between"><span>🧪 QA</span><span class="text-yellow-400">●</span></div><div class="text-sm text-zinc-400 mt-2">Running Tests</div><div class="mt-3 text-xs">Success: 94%</div></div>
            </div>

            <!-- Workflow Pipeline (Dynamic) -->
            <div id="workflowPipeline" class="grid grid-cols-8 gap-2 text-center"></div>

            <!-- Three columns -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
                <div class="glass p-5">
                    <h3 class="text-md font-semibold mb-3"><i class="fas fa-diagram-project ml-2"></i> Architecture Explorer</h3>
                    <div id="architectureTree" class="text-xs space-y-1 overflow-y-auto max-h-80"></div>
                </div>
                <div class="space-y-5">
                    <div class="glass p-5">
                        <h3 class="text-md font-semibold mb-3"><i class="fas fa-terminal ml-2"></i> Mission Commander</h3>
                        <div class="flex gap-2">
                            <input type="text" id="commandInput" placeholder="Ask JAOLA Team..." class="flex-1 bg-[#111827] border border-[#27272A] rounded-xl px-4 py-3 text-sm outline-none">
                            <button id="executeMissionBtn" class="bg-blue-600 hover:bg-blue-700 px-6 rounded-xl transition">Execute</button>
                        </div>
                    </div>
                    <div class="glass p-5">
                        <h3 class="text-md font-semibold mb-3"><i class="fas fa-chart-line ml-2"></i> Agent Timeline</h3>
                        <div id="agentTimeline" class="space-y-2 text-sm font-mono max-h-80 overflow-y-auto"></div>
                    </div>
                </div>
                <div class="glass p-5 flex flex-col">
                    <div class="flex justify-between items-center mb-3">
                        <h3 class="text-md font-semibold"><i class="fas fa-eye ml-2"></i> Live Preview</h3>
                        <div class="flex gap-2">
                            <button id="reloadPreviewBtn" class="bg-gray-700 hover:bg-gray-600 text-xs px-2 py-1 rounded">🔄 Refresh</button>
                            <button id="startDevServerBtn" class="bg-green-700 hover:bg-green-600 text-xs px-2 py-1 rounded">▶️ Start Dev Server</button>
                        </div>
                    </div>
                    <div id="previewStatus" class="text-xs text-gray-400 mb-2 flex items-center gap-2">
                        <span id="previewIndicator" class="inline-block w-2 h-2 bg-gray-500 rounded-full"></span>
                        <span id="previewStatusText">Checking...</span>
                    </div>
                    <iframe id="livePreviewFrame" src="about:blank" class="rounded-xl flex-1 min-h-[400px]"></iframe>
                </div>
            </div>
        </main>
    </div>

    <script>
        // Helper functions
        let token = localStorage.getItem('token');
        let ws = null;
        let timelineEvents = [];

        function addTimelineEvent(message, type = 'info') {
            timelineEvents.unshift({ time: new Date().toLocaleTimeString(), message, type });
            if (timelineEvents.length > 50) timelineEvents.pop();
            const container = document.getElementById('agentTimeline');
            container.innerHTML = timelineEvents.map(e => `<div class="border-r-2 border-${e.type === 'error' ? 'red' : e.type === 'success' ? 'green' : 'blue'}-500 pr-2 pb-1 mb-1">${e.time} — ${e.message}</div>`).join('');
        }

        // API calls without token (all public except /user/request)
        async function apiGet(endpoint) {
            const res = await fetch(endpoint);
            if (!res.ok) throw new Error(`${endpoint} returned ${res.status}`);
            return res.json();
        }

        async function apiPost(endpoint, body) {
            const headers = { 'Content-Type': 'application/json' };
            if (token) headers['Authorization'] = `Bearer ${token}`;
            const res = await fetch(endpoint, { method: 'POST', headers, body: JSON.stringify(body) });
            if (!res.ok) throw new Error(await res.text());
            return res.json();
        }

        // Fetch data
        async function fetchProjects() { return await apiGet('/api/projects'); }
        async function fetchActiveProject() { return await apiGet('/api/projects/active'); }
        async function fetchKPIs() { return await apiGet('/api/kpis'); }
        async function fetchArchitectureTree() { return await apiGet('/api/architecture/tree'); }
        async function fetchWorkflow() { return await apiGet('/api/workflow/status/live'); }

        // Render functions
        async function renderProjectsSidebar() {
            const projects = await fetchProjects();
            const active = await fetchActiveProject();
            const container = document.getElementById('projectsList');
            container.innerHTML = projects.map(p => `
                <div class="flex justify-between p-2 rounded-lg cursor-pointer hover:bg-zinc-800/50 ${p.id === active?.id ? 'bg-blue-900/30 border-r border-blue-500' : ''}" data-id="${p.id}">
                    <span>${p.name}</span>${p.id === active?.id ? '<i class="fas fa-check-circle text-blue-500 text-xs"></i>' : ''}
                </div>
            `).join('');
            document.querySelectorAll('[data-id]').forEach(el => {
                el.addEventListener('click', async () => {
                    await fetch(`/api/projects/active/${el.dataset.id}`, { method: 'POST' });
                    renderProjectsSidebar();
                    refreshAll();
                });
            });
            return { projects, active };
        }

        async function renderHeroAndKPIs() {
            const kpis = await fetchKPIs();
            const active = await fetchActiveProject();
            if (active) {
                document.getElementById('activeProjectName').innerText = active.name;
                const progress = kpis.buildSuccessRate || 0;
                document.getElementById('progressPercent').innerText = `${progress}%`;
                const circle = document.getElementById('progressCircle');
                const circumference = 2 * Math.PI * 42;
                circle.style.strokeDasharray = circumference;
                circle.style.strokeDashoffset = circumference * (1 - progress / 100);
            }
            const projects = await fetchProjects();
            document.getElementById('kpiProjects').innerText = projects.length;
            document.getElementById('kpiTasks').innerText = kpis.totalTasks || 0;
            document.getElementById('kpiDeployments').innerText = kpis.deploySuccessRate ? Math.round((kpis.deploySuccessRate/100)*(kpis.totalTasks||0)) : 0;
            document.getElementById('kpiBuildSuccess').innerText = `${kpis.buildSuccessRate || 0}%`;
            document.getElementById('kpiAutoFix').innerText = `${kpis.autoFixRate || 0}%`;
        }

        async function renderArchitectureTree() {
            const tree = await fetchArchitectureTree();
            function renderTree(obj) {
                let html = '<ul class="tree" style="list-style:none; padding-right:1rem;">';
                for (const [key, val] of Object.entries(obj)) {
                    if (key === '__files') {
                        val.forEach(file => html += `<li style="margin:0.25rem 0;">📄 ${file}</li>`);
                    } else if (typeof val === 'object') {
                        html += `<li><details><summary style="cursor:pointer;">📁 ${key}</summary>${renderTree(val)}</details></li>`;
                    } else {
                        html += `<li>📄 ${key}</li>`;
                    }
                }
                html += '</ul>';
                return html;
            }
            document.getElementById('architectureTree').innerHTML = renderTree(tree) || '<div class="text-gray-500">No structure</div>';
        }

        async function renderWorkflowPipeline() {
            const steps = await fetchWorkflow();
            const container = document.getElementById('workflowPipeline');
            const icons = {
                'المتطلبات': '💡', 'التصميم': '🏗', 'التخطيط': '📑', 'التطوير': '💻',
                'المراجعة': '🔍', 'الاختبار': '🧪', 'النشر': '🚀', 'المراقبة': '📊',
                'Requirements': '💡', 'Architecture': '🏗', 'Planning': '📑', 'Development': '💻',
                'Review': '🔍', 'Testing': '🧪', 'Deploy': '🚀', 'Monitoring': '📊'
            };
            container.innerHTML = steps.map(step => `
                <div class="glass rounded-xl p-2 workflow-card cursor-pointer transition hover:bg-blue-900/20" data-step="${step.name.toLowerCase()}">
                    <div class="text-2xl">${icons[step.name] || '📋'}</div>
                    <div class="text-xs mt-1">${step.name}</div>
                    <div class="w-full h-1 mt-2 rounded-full ${step.status === 'completed' ? 'bg-green-500' : step.status === 'current' ? 'bg-blue-500' : 'bg-gray-600'}"></div>
                </div>
            `).join('');
        }

        async function refreshAll() {
            await renderProjectsSidebar();
            await renderHeroAndKPIs();
            await renderArchitectureTree();
            await renderWorkflowPipeline();
        }

        // Preview & Dev Server
        async function checkPreviewStatus() {
            try {
                const controller = new AbortController();
                setTimeout(() => controller.abort(), 2000);
                await fetch('http://localhost:3000', { signal: controller.signal });
                document.getElementById('previewIndicator').className = 'inline-block w-2 h-2 bg-green-500 rounded-full';
                document.getElementById('previewStatusText').innerText = 'Online (localhost:3000)';
                document.getElementById('livePreviewFrame').src = 'http://localhost:3000';
            } catch(e) {
                document.getElementById('previewIndicator').className = 'inline-block w-2 h-2 bg-red-500 rounded-full';
                document.getElementById('previewStatusText').innerText = 'Offline - click Start Dev Server';
                document.getElementById('livePreviewFrame').src = 'about:blank';
            }
        }

        async function startDevServer() {
            addTimelineEvent('Starting dev server...', 'info');
            try {
                const res = await fetch('/api/run-dev', { method: 'POST' });
                const data = await res.json();
                if (data.running || data.started) {
                    addTimelineEvent('Dev server started or already running', 'success');
                    setTimeout(() => checkPreviewStatus(), 3000);
                } else {
                    addTimelineEvent('Failed to start dev server', 'error');
                }
            } catch(err) {
                addTimelineEvent(`Error: ${err.message}`, 'error');
            }
        }

        function reloadPreview() { checkPreviewStatus(); addTimelineEvent('Preview refreshed', 'info'); }

        // Mission execution
        async function sendMission(message) {
            if (!message.trim()) return;
            addTimelineEvent(`🚀 Mission: ${message}`, 'info');
            try {
                const data = await apiPost('/api/user/request', { message });
                addTimelineEvent(`✅ Plan created: ${data.planId} (${data.tasksCount} tasks)`, 'success');
                refreshAll();
            } catch(err) {
                addTimelineEvent(`❌ Error: ${err.message}`, 'error');
            }
        }

        // WebSocket (for real-time updates)
        function connectWebSocket() {
            const protocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
            ws = new WebSocket(`${protocol}//${location.host}`);
            ws.onmessage = (event) => {
                try {
                    const data = JSON.parse(event.data);
                    if (data.type === 'task_update') {
                        addTimelineEvent(`${data.agent || 'Agent'} ${data.status} ${data.action || ''}`, data.status === 'failed' ? 'error' : 'success');
                        refreshAll();
                    }
                    if (data.type === 'plan_update') addTimelineEvent(`📋 New plan: ${data.goal}`, 'info');
                } catch(e) {}
            };
            ws.onclose = () => setTimeout(connectWebSocket, 3000);
        }

        // Auth UI
        async function loadUser() {
            if (token) {
                try {
                    const res = await fetch('/api/user/profile', { headers: { Authorization: `Bearer ${token}` } });
                    if (res.ok) {
                        const user = await res.json();
                        document.getElementById('usernameDisplay').innerText = user.username || 'Developer';
                        return;
                    }
                } catch(e) {}
            }
            document.getElementById('usernameDisplay').innerText = 'Guest';
        }

        document.getElementById('executeMissionBtn').onclick = () => sendMission(document.getElementById('commandInput').value);
        document.getElementById('reloadPreviewBtn').onclick = reloadPreview;
        document.getElementById('startDevServerBtn').onclick = startDevServer;
        document.getElementById('logoutBtn').onclick = () => { localStorage.removeItem('token'); location.reload(); };
        document.getElementById('newProjectBtn').onclick = async () => {
            const name = prompt('Project name:');
            const path = prompt('Absolute path:');
            if (name && path) {
                await fetch('/api/projects', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name, path }) });
                refreshAll();
            }
        };

        loadUser();
        refreshAll();
        connectWebSocket();
        checkPreviewStatus();
        setInterval(refreshAll, 10000);
        setInterval(checkPreviewStatus, 15000);
    </script>
</body>
</html>
