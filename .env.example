# 💳 نظام الاشتراكات والدفع (Stripe) — JAOLA OS
# انسخ هذا الملف إلى .env واملأ القيم. بدون هذه المتغيرات يعمل النظام في
# "وضع العرض": تظهر الخطط والاستهلاك، لكن زر الترقية معطّل بأمان.

# مفتاح Stripe السري (لوحة تحكم Stripe → Developers → API keys)
STRIPE_SECRET_KEY=

# سر توقيع الـ webhook (Developers → Webhooks → أضف endpoint: /api/billing/webhook)
STRIPE_WEBHOOK_SECRET=

# معرّفات أسعار الاشتراك الشهري (Products → أنشئ منتجاً بسعر متكرر → انسخ price_...)
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# روابط العودة بعد الدفع (اختياري — لها قيم افتراضية للتطوير المحلي)
BILLING_SUCCESS_URL=http://localhost:5173/settings?billing=success
BILLING_CANCEL_URL=http://localhost:5173/settings?billing=cancel
BILLING_PORTAL_RETURN_URL=http://localhost:5173/settings
