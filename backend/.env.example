# ═══════════════════════════════════════════════════════════════
# JAOLA OS — نموذج متغيرات البيئة (انسخه إلى .env واملأ القيم)
# ═══════════════════════════════════════════════════════════════

# — أساسي —
JWT_SECRET=change-me-to-a-long-random-string
MONGODB_URI=mongodb+srv://...            # اختياري: بدونه يعمل بوضع offline محدود
PAT_ENCRYPTION_KEY=another-long-random-string   # تشفير التوكنات (يُستخدم JWT_SECRET كاحتياط)

# — نماذج الذكاء (failover) —
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# — CORS —
# نطاقات الواجهة المسموح لها (مفصولة بفواصل). في الإنتاج يُضاف RENDER_EXTERNAL_URL تلقائياً.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ═══════════════════════════════════════════════════════════════
# 🔑 OAuth — الدخول عبر GitHub / Google (اختياري)
# إن لم تُضبط مفاتيح مزوّد، يُخفى زره في الواجهة تلقائياً (تحلّل بلطف).
# ═══════════════════════════════════════════════════════════════

# عنوان الواجهة للعودة إليها بعد نجاح OAuth. اتركه فارغاً إن كانت الواجهة
# تُقدَّم من نفس الخادم (الافتراضي في الإنتاج) — سيعود إلى /dashboard.
FRONTEND_URL=

# GitHub OAuth App:
#  Homepage URL:            https://<your-domain>
#  Authorization callback:  https://<your-domain>/api/auth/github/callback
#  (scope المطلوب read:user user:email repo — للوصول لملفات المستودعات)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (Google Cloud Console → Credentials → OAuth client ID → Web):
#  Authorized redirect URI: https://<your-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# — ADMIN —
# أسماء المستخدمين المصرّح لهم بلوحة الأدمِن (مفصولة بفواصل)
ADMIN_USERS=
