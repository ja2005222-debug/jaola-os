{
  "global": {
    "fonts": {
      "arabic": ["Cairo", "Tajawal", "Almarai", "Noto Kufi Arabic"],
      "heading": "Cairo",
      "body": "Tajawal",
      "google_import": "@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Tajawal:wght@400;500;700&display=swap');"
    },
    "icons": "Font Awesome 6 (CDN: https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css)",
    "images": {
      "source": "Unsplash",
      "pattern": "https://images.unsplash.com/photo-{ID}?w=800&q=80&auto=format&fit=crop",
      "rule": "استخدم صور واقعية ومناسبة للمحتوى، لا placeholder"
    },
    "css_rules": [
      "استخدم CSS Variables في :root لكل الألوان",
      "Reset CSS في البداية (* { box-sizing: border-box; margin: 0; padding: 0; })",
      "Mobile-first: ابدأ بالجوال، استخدم @media للشاشات الكبيرة",
      "Smooth transitions على كل التفاعلات (transition: all 0.3s ease)",
      "Hover effects واضحة على كل العناصر التفاعلية",
      "حدد لون النص صراحةً لكل element رئيسي لتجنب مشاكل التباين",
      "استخدم CSS Grid للتخطيط العام وFlexbox للمكونات الصغيرة"
    ],
    "html_rules": [
      "DOCTYPE html وmeta charset وviewport إلزامية",
      "dir=rtl lang=ar على الـ html",
      "هيكل HTML5 معنوي: header, main, section, footer",
      "محتوى واقعي ومفصّل: أسماء حقيقية، أرقام، وصف — لا placeholder",
      "اربط Google Fonts وFont Awesome وstyles.css وscript.js"
    ],
    "js_rules": [
      "'use strict' في البداية",
      "DOMContentLoaded للتهيئة",
      "Vanilla JS فقط — لا jQuery",
      "قائمة متحركة للجوال (hamburger menu)",
      "Smooth scroll للروابط الداخلية",
      "Form validation للنماذج"
    ]
  },
