
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>JAOLA OS | Mission Control</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/diff2html/bundles/css/diff2html.min.css">
    <script src="https://cdn.jsdelivr.net/npm/diff2html/bundles/js/diff2html-ui.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/diff/dist/diff.min.js"></script>
    <style>
        * { font-family: 'Inter', 'Tajawal', sans-serif; }
        body { background: #09090B; color: #e5e7eb; scroll-behavior: smooth; }
        .glass {
            background: rgba(17, 24, 39, 0.7);
            backdrop-filter: blur(4px);
            border: 1px solid #27272A;
            border-radius: 1.5rem;
        }
        .glass-panel {
            background: rgba(17, 24, 39, 0.5);
            backdrop-filter: blur(2px);
            border: 1px solid #27272A;
        }
        ::-webkit-scrollbar { width: 5px; height: 5px; }
        ::-webkit-scrollbar-track { background: #18181B; border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: #3b82f6; border-radius: 10px; }
        .status-running { animation: pulse 1.5s infinite; }
        @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.6; } }
        .agent-card { transition: all 0.2s ease; border-left: 3px solid transparent; }
        .agent-card:hover { border-left-color: #3b82f6; background: rgba(59,130,246,0.05); }
        .workflow-card { transition: transform 0.1s ease; cursor: pointer; }
        .workflow-card:hover { transform: translateY(-2px); background: rgba(59,130,246,0.2); }
        iframe { border: none; width: 100%; height: 500px; background: white; border-radius: 1rem; }
        .tree, .tree ul { list-style: none; margin: 0; padding: 0 0 0 1.2rem; }
        .tree li { position: relative; margin: 0.5rem 0; }
        .tree li::before { content: '📁'; position: absolute; right: -1.2rem; top: 0; }
        .file::before { content: '📄' !important; }
        .animate-pulse { animation: pulse-opacity 1.5s infinite; }
        @keyframes pulse-opacity { 0%,100% { opacity: 0.6; } 50% { opacity: 1; } }
        .plan-step { display: inline-block; background: #1e293b; border-radius: 1rem; padding: 0.2rem 0.6rem; margin: 0.2rem; font-size: 0.7rem; }
        .task-status-pending { border-right-color: #9ca3af; }
        .task-status-running { border-right-color: #3b82f6; }
        .task-status-completed { border-right-color: #10b981; }
        .task-status-failed { border-right-color: #ef4444; }
        .task-item { transition: all 0.2s; }
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden">

<div class="flex flex-1 overflow-hidden">
    <!-- SIDEBAR (نفس السابق) -->
    <aside class="w-80 flex-shrink-0 bg-[#09090B] border-l border-[#27272A] flex flex-col p-5 overflow-y-auto">
        <div class="mb-8">
            <h1 class="text-2xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">JAOLA OS</h1>
            <p class="text-xs text-gray-500">Autonomous Software Engineering Platform</p>
        </div>
        <div class="mb-6">
            <div class="flex justify-between items-center mb-2">
                <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">PROJECTS</h3>
                <div>
                    <button id="newProjectBtn" class="text-xs text-blue-400 hover:text-blue-300 ml-2"><i class="fas fa-plus"></i> New</button>
                    <button id="newScratchProjectBtn" class="text-xs text-green-400 hover:text-green-300"><i class="fas fa-code-branch"></i> Scratch</button>
                </div>
            </div>
            <div id="projectsList" class="space-y-1 max-h-48 overflow-y-auto pr-1"></div>
        </div>
        <nav class="mb-6">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">MENU</h3>
            <div class="space-y-1">
                <a href="#" class="flex items-center gap-3 p-2 rounded-lg bg-blue-900/30 text-blue-400"><i class="fas fa-tachometer-alt w-5"></i> Mission Control</a>
                <a href="#" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-microchip w-5"></i> Agents Center</a>
                <a href="#" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-project-diagram w-5"></i> Architecture</a>
                <a href="#" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-chart-line w-5"></i> Workflow</a>
                <a href="#" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-folder-open w-5"></i> Projects</a>
                <a href="#" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-brain w-5"></i> Decisions</a>
                <a href="#" class="flex items-center gap-3 p-2 rounded-lg hover:bg-zinc-800"><i class="fas fa-cog w-5"></i> Settings</a>
            </div>
        </nav>
        <div class="mt-auto pt-4 border-t border-[#27272A] flex items-center justify-between">
            <div class="flex items-center gap-2">
                <i class="fas fa-user-circle text-2xl text-gray-400"></i>
                <div>
                    <div id="usernameDisplay" class="text-sm font-medium">Developer</div>
                    <div class="text-xs text-gray-500">Pro Plan</div>
                </div>
            </div>
            <button id="logoutBtn" class="text-xs text-gray-500 hover:text-white"><i class="fas fa-sign-out-alt"></i></button>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 flex flex-col overflow-hidden p-5 gap-5">
        <!-- Hero + Progress Ring (نفس السابق) -->
        <div class="glass p-5 flex justify-between items-center">
            <div>
                <div class="text-sm text-gray-400">Active Project</div>
                <h2 id="activeProjectName" class="text-2xl font-bold">Loading...</h2>
                <div class="flex items-center gap-2 mt-1">
                    <span class="inline-block w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                    <span id="projectStatus" class="text-xs text-green-400">ACTIVE</span>
                </div>
            </div>
            <div class="relative w-20 h-20">
                <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="42" fill="none" stroke="#27272A" stroke-width="6"/>
                    <circle id="progressCircle" cx="50" cy="50" r="42" fill="none" stroke="#3b82f6" stroke-width="6" stroke-linecap="round"
                            stroke-dasharray="263.89" stroke-dashoffset="263.89"/>
                </svg>
                <div id="progressPercent" class="absolute inset-0 flex items-center justify-center text-sm font-bold">0%</div>
            </div>
        </div>

        <!-- KPI Cards (نفس السابق) -->
        <div class="grid grid-cols-5 gap-4">
            <div class="glass-panel p-3 rounded-xl text-center"><div class="text-2xl font-bold" id="kpiProjects">—</div><div class="text-xs text-gray-400">Projects</div></div>
            <div class="glass-panel p-3 rounded-xl text-center"><div class="text-2xl font-bold" id="kpiTasks">—</div><div class="text-xs text-gray-400">Tasks</div></div>
            <div class="glass-panel p-3 rounded-xl text-center"><div class="text-2xl font-bold text-green-400" id="kpiDeployments">—</div><div class="text-xs text-gray-400">Deployments</div></div>
            <div class="glass-panel p-3 rounded-xl text-center"><div class="text-2xl font-bold text-blue-400" id="kpiBuildSuccess">—%</div><div class="text-xs text-gray-400">Build Success</div></div>
            <div class="glass-panel p-3 rounded-xl text-center"><div class="text-2xl font-bold text-purple-400" id="kpiAutoFix">—%</div><div class="text-xs text-gray-400">AutoFix</div></div>
        </div>

        <!-- AI Team Grid (نفس السابق) -->
        <div id="agentsGrid" class="grid grid-cols-2 gap-4">
            <div class="glass rounded-2xl p-4">
                <div class="flex justify-between"><span>🧠 Architect</span><span class="text-green-400">●</span></div>
                <div class="text-sm text-zinc-400 mt-2" id="agent-architect-task">Idle</div>
                <div class="mt-3 text-xs">Success: <span id="agent-architect-success">—</span>%</div>
            </div>
            <div class="glass rounded-2xl p-4">
                <div class="flex justify-between"><span>📋 Planner</span><span class="text-blue-400">●</span></div>
                <div class="text-sm text-zinc-400 mt-2" id="agent-planner-task">Idle</div>
                <div class="mt-3 text-xs">Success: <span id="agent-planner-success">—</span>%</div>
            </div>
            <div class="glass rounded-2xl p-4">
                <div class="flex justify-between"><span>💻 Coder</span><span class="text-green-400">●</span></div>
                <div class="text-sm text-zinc-400 mt-2" id="agent-coder-task">Idle</div>
                <div class="mt-3 text-xs">Success: <span id="agent-coder-success">—</span>%</div>
            </div>
            <div class="glass rounded-2xl p-4">
                <div class="flex justify-between"><span>🧪 QA</span><span class="text-yellow-400">●</span></div>
                <div class="text-sm text-zinc-400 mt-2" id="agent-qa-task">Idle</div>
                <div class="mt-3 text-xs">Success: <span id="agent-qa-success">—</span>%</div>
            </div>
        </div>

        <!-- Workflow Pipeline (نفس السابق) -->
        <div id="workflowPipeline" class="grid grid-cols-8 gap-2 text-center"></div>

        <!-- ========== Mission Execution Flow (Step 3) ========== -->
        <div id="currentPlanDisplay" class="glass p-4 hidden">
            <div class="font-bold text-lg mb-2">🎯 Mission Execution Flow</div>
            <div id="planGoal" class="text-gray-300 mb-3"></div>
            <div id="planTasksList" class="space-y-2"></div>
            <div id="planResult" class="mt-3 text-sm text-gray-400 hidden"></div>
        </div>

        <!-- Three columns (Architecture Explorer, Command Bar+Timeline, Live Preview) -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
            <!-- Architecture Explorer -->
            <div class="glass p-5">
                <h3 class="text-md font-semibold mb-3 flex items-center gap-2"><i class="fas fa-diagram-project"></i> Architecture Explorer</h3>
                <div id="architectureTree" class="text-xs space-y-1 overflow-y-auto max-h-80"></div>
            </div>

            <!-- Center: Command Bar + Timeline -->
            <div class="space-y-5">
                <div class="glass p-5">
                    <h3 class="text-md font-semibold mb-3 flex items-center gap-2"><i class="fas fa-terminal"></i> Mission Commander</h3>
                    <div class="flex gap-2">
                        <input type="text" id="commandInput" placeholder="Ask JAOLA Team... (e.g., Add a login page)" class="flex-1 bg-[#111827] border border-[#27272A] rounded-xl px-4 py-3 text-sm outline-none focus:ring-1 focus:ring-blue-500">
                        <button id="executeMissionBtn" class="bg-blue-600 hover:bg-blue-700 px-6 rounded-xl transition text-sm font-medium">Execute</button>
                    </div>
                </div>
                <div class="glass p-5">
                    <h3 class="text-md font-semibold mb-3 flex items-center gap-2"><i class="fas fa-chart-line"></i> Agent Timeline</h3>
                    <div id="agentTimeline" class="space-y-2 text-sm font-mono max-h-80 overflow-y-auto"></div>
                </div>
            </div>

            <!-- Live Preview -->
            <div class="glass p-5 flex flex-col">
                <div class="flex justify-between items-center mb-3">
                    <h3 class="text-md font-semibold flex items-center gap-2"><i class="fas fa-eye"></i> Live Preview</h3>
                    <div class="flex gap-2">
                        <button id="reloadPreviewBtn" class="bg-gray-700 hover:bg-gray-600 text-xs px-2 py-1 rounded">🔄 Refresh</button>
                        <button id="startDevServerBtn" class="bg-green-700 hover:bg-green-600 text-xs px-2 py-1 rounded">▶️ Start Dev Server</button>
                    </div>
                </div>
                <div id="previewStatus" class="text-xs text-gray-400 mb-2 flex items-center gap-2">
                    <span id="previewIndicator" class="inline-block w-2 h-2 bg-gray-500 rounded-full"></span>
                    <span id="previewStatusText">Checking...</span>
                </div>
                <iframe id="livePreviewFrame" src="about:blank" class="rounded-xl flex-1 min-h-[400px]"></iframe>
            </div>
        </div>
    </main>
</div>

<script>
    // ---------- AUTH & Globals ----------
    let token = localStorage.getItem('token');
    if (!token) window.location.href = '/user.html';
    let ws = null;
    let timelineEvents = [];
    let currentPlan = null;       // تخزين الخطة الحالية { goal, tasks, result }
    let taskStatusMap = new Map(); // taskId -> status

    // Helper functions
    function escapeHtml(str) { return str.replace(/[&<>]/g, m => m === '&' ? '&amp;' : m === '<' ? '&lt;' : '&gt;'); }
    function addTimelineEvent(message, type = 'info') {
        timelineEvents.unshift({ time: new Date().toLocaleTimeString(), message, type });
        if (timelineEvents.length > 50) timelineEvents.pop();
        const container = document.getElementById('agentTimeline');
        container.innerHTML = timelineEvents.map(e => `<div class="border-r-2 border-${e.type === 'error' ? 'red' : e.type === 'success' ? 'green' : 'blue'}-500 pr-2 pb-1 mb-1">${e.time} — ${escapeHtml(e.message)}</div>`).join('');
    }

    // API calls
    async function apiGet(endpoint) {
        const res = await fetch(endpoint, { headers: { Authorization: `Bearer ${token}` } });
        if (!res.ok) throw new Error(`${endpoint} returned ${res.status}`);
        return res.json();
    }
    async function apiPost(endpoint, body) {
        const res = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
            body: JSON.stringify(body)
        });
        if (!res.ok) throw new Error(await res.text());
        return res.json();
    }

    // Data fetching functions (مثل السابق)
    async function fetchProjects() { return apiGet('/api/projects'); }
    async function fetchActiveProject() { return apiGet('/api/projects/active'); }
    async function fetchKPIs() { return apiGet('/api/kpis'); }
    async function fetchAgentsHealth() { return apiGet('/api/agents/health'); }
    async function fetchWorkflow() { return apiGet('/api/workflow/status/live'); }
    async function fetchStructuredArchitecture() { return apiGet('/api/architecture/structured'); }

    // Render functions (Sidebar, KPI, Agents metrics, Workflow, Architecture)
    async function renderSidebarProjects() {
        const projects = await fetchProjects();
        const active = await fetchActiveProject();
        const container = document.getElementById('projectsList');
        container.innerHTML = projects.map(p => `
            <div class="flex justify-between p-2 rounded-lg cursor-pointer hover:bg-zinc-800/50 ${p.id === active?.id ? 'bg-blue-900/30 border-r border-blue-500' : ''}" data-id="${p.id}">
                <span>${escapeHtml(p.name)}</span>${p.id === active?.id ? '<i class="fas fa-check-circle text-blue-500 text-xs"></i>' : ''}
            </div>
        `).join('');
        document.querySelectorAll('[data-id]').forEach(el => {
            el.addEventListener('click', async () => {
                await fetch(`/api/projects/active/${el.dataset.id}`, { method: 'POST', headers: { Authorization: `Bearer ${token}` } });
                await refreshAll();
            });
        });
        return active;
    }

    async function renderHeroAndKPIs() {
        const kpis = await fetchKPIs();
        const active = await fetchActiveProject();
        if (active) {
            document.getElementById('activeProjectName').innerText = active.name;
            const progress = kpis.buildSuccessRate || 0;
            document.getElementById('progressPercent').innerText = `${progress}%`;
            const circle = document.getElementById('progressCircle');
            const circumference = 2 * Math.PI * 42;
            circle.style.strokeDasharray = circumference;
            circle.style.strokeDashoffset = circumference * (1 - progress / 100);
        }
        const projects = await fetchProjects();
        document.getElementById('kpiProjects').innerText = projects.length;
        document.getElementById('kpiTasks').innerText = kpis.totalTasks || 0;
        const deployments = kpis.deploySuccessRate ? Math.round((kpis.deploySuccessRate/100)*(kpis.totalTasks||0)) : 0;
        document.getElementById('kpiDeployments').innerText = deployments;
        document.getElementById('kpiBuildSuccess').innerText = `${kpis.buildSuccessRate || 0}%`;
        document.getElementById('kpiAutoFix').innerText = `${kpis.autoFixRate || 0}%`;
    }

    async function renderAgentsMetrics() {
        const health = await fetchAgentsHealth();
        const agents = ['Architect', 'Planner', 'Coder', 'QA'];
        for (const agent of agents) {
            const info = health[agent];
            if (info) {
                document.getElementById(`agent-${agent.toLowerCase()}-success`).innerText = info.successRate || 0;
                document.getElementById(`agent-${agent.toLowerCase()}-task`).innerText = info.action || 'Idle';
            }
        }
    }

    async function renderWorkflowPipeline() {
        const steps = await fetchWorkflow();
        const container = document.getElementById('workflowPipeline');
        const icons = { 'Requirements': '💡', 'Architecture': '🏗', 'Planning': '📑', 'Development': '💻',
                        'Review': '🔍', 'Testing': '🧪', 'Deploy': '🚀', 'Monitoring': '📊' };
        container.innerHTML = steps.map(step => `
            <div class="glass rounded-xl p-2 workflow-card" data-step="${step.name.toLowerCase()}">
                <div class="text-2xl">${icons[step.name] || '📋'}</div>
                <div class="text-xs mt-1">${step.name}</div>
                <div class="w-full h-1 mt-2 rounded-full ${step.status === 'completed' ? 'bg-green-500' : step.status === 'current' ? 'bg-blue-500' : 'bg-gray-600'}"></div>
            </div>
        `).join('');
    }

    async function renderStructuredArchitecture() {
        try {
            const data = await fetchStructuredArchitecture();
            let html = '<div class="space-y-3 text-sm">';
            // Frontend
            html += '<details open><summary class="cursor-pointer font-semibold text-blue-400">📱 Frontend</summary>';
            html += '<ul class="mr-4 space-y-1">';
            if (data.Frontend?.pages?.length) html += `<li>📄 Pages: ${data.Frontend.pages.join(', ')}</li>`;
            if (data.Frontend?.components?.length) html += `<li>🧩 Components: ${data.Frontend.components.join(', ')}</li>`;
            html += '</ul></details>';
            // Backend
            html += '<details><summary class="cursor-pointer font-semibold text-green-400">⚙️ Backend</summary>';
            html += '<ul class="mr-4 space-y-1">';
            if (data.Backend?.apis?.length) html += `<li>🔌 APIs: ${data.Backend.apis.join(', ')}</li>`;
            if (data.Backend?.services?.length) html += `<li>🛠️ Services: ${data.Backend.services.join(', ')}</li>`;
            html += '</ul></details>';
            // Database
            html += '<details><summary class="cursor-pointer font-semibold text-yellow-400">🗄️ Database</summary>';
            html += '<ul class="mr-4 space-y-1">';
            if (data.Database?.tables?.length) html += `<li>📊 Tables: ${data.Database.tables.join(', ')}</li>`;
            else html += '<li class="text-gray-500">No tables indexed yet</li>';
            html += '</ul></details>';
            // Agents
            html += '<details><summary class="cursor-pointer font-semibold text-purple-400">🤖 Agents</summary>';
            html += '<ul class="mr-4 space-y-1">';
            (data.Agents || []).forEach(agent => {
                html += `<li>🧠 ${agent.name} <span class="text-green-400 text-xs">● ${agent.status}</span></li>`;
            });
            html += '</ul></details>';
            document.getElementById('architectureTree').innerHTML = html;
        } catch (err) {
            console.error(err);
            document.getElementById('architectureTree').innerHTML = '<div class="text-red-500">Failed to load architecture</div>';
        }
    }

    // ---------- Plan Display & Execution Flow (Step 3) ----------
    function updatePlanDisplay(goal, tasks, result = null) {
        const container = document.getElementById('currentPlanDisplay');
        if (!container) return;
        if (!goal || !tasks || tasks.length === 0) {
            container.classList.add('hidden');
            currentPlan = null;
            return;
        }
        container.classList.remove('hidden');
        document.getElementById('planGoal').innerHTML = `<i class="fas fa-bullseye"></i> Goal: ${escapeHtml(goal)}`;
        // Build tasks list
        const tasksContainer = document.getElementById('planTasksList');
        let tasksHtml = '';
        for (const task of tasks) {
            const status = taskStatusMap.get(task.id) || task.status || 'pending';
            let statusIcon = '';
            let statusClass = '';
            if (status === 'pending') { statusIcon = '⏳'; statusClass = 'task-status-pending'; }
            else if (status === 'running') { statusIcon = '⚙️'; statusClass = 'task-status-running'; }
            else if (status === 'completed') { statusIcon = '✅'; statusClass = 'task-status-completed'; }
            else if (status === 'failed') { statusIcon = '❌'; statusClass = 'task-status-failed'; }
            tasksHtml += `
                <div class="task-item flex items-center justify-between p-2 rounded-lg bg-zinc-800/30 border-r-4 ${statusClass}">
                    <div class="flex items-center gap-2">
                        <span class="text-lg">${statusIcon}</span>
                        <div>
                            <div class="font-mono text-sm">${task.agent} → ${task.action}</div>
                            <div class="text-xs text-gray-400">${task.params?.path || ''}</div>
                        </div>
                    </div>
                    <div class="text-xs font-semibold">${status}</div>
                </div>
            `;
        }
        tasksContainer.innerHTML = tasksHtml;
        const resultDiv = document.getElementById('planResult');
        if (result) {
            resultDiv.classList.remove('hidden');
            resultDiv.innerHTML = `<i class="fas fa-flag-checkered"></i> Result: ${escapeHtml(result)}`;
        } else {
            resultDiv.classList.add('hidden');
        }
        currentPlan = { goal, tasks, result };
    }

    // تحديث حالة مهمة معينة في الخطة
    function updateTaskStatusInPlan(taskId, status, resultData = null) {
        if (!currentPlan) return;
        const task = currentPlan.tasks.find(t => t.id === taskId);
        if (task) {
            task.status = status;
            taskStatusMap.set(taskId, status);
            updatePlanDisplay(currentPlan.goal, currentPlan.tasks, currentPlan.result);
        }
        // إذا اكتملت كل المهام، نعرض النتيجة (يمكن استنتاجها من آخر مهمة deploy مثلاً)
        const allCompleted = currentPlan.tasks.every(t => t.status === 'completed');
        if (allCompleted && !currentPlan.result) {
            // حاول استخراج رابط النشر من resultData
            let finalResult = 'All tasks completed successfully.';
            if (resultData && resultData.url) finalResult = `Deployed at: ${resultData.url}`;
            currentPlan.result = finalResult;
            updatePlanDisplay(currentPlan.goal, currentPlan.tasks, finalResult);
        }
    }

    // ---------- Mission Execution ----------
    async function sendMission(message) {
        if (!message.trim()) return;
        addTimelineEvent(`🚀 Mission: ${message}`, 'info');
        try {
            const data = await apiPost('/api/user/request', { message });
            if (data.planId) {
                addTimelineEvent(`✅ Plan created: ${data.planId} (${data.tasksCount} tasks)`, 'success');
                // جلب تفاصيل الخطة
                const planDetails = await apiGet(`/api/user/plan/${data.planId}`);
                const tasks = planDetails.tasks || [];
                // تهيئة المهام في الخريطة
                taskStatusMap.clear();
                for (const task of tasks) {
                    taskStatusMap.set(task.id, task.status || 'pending');
                }
                updatePlanDisplay(planDetails.plan?.goal || message, tasks, null);
                refreshAll();
            } else {
                addTimelineEvent(`❌ Error: ${data.error || 'Unknown'}`, 'error');
            }
        } catch (err) {
            addTimelineEvent(`❌ Network error: ${err.message}`, 'error');
        }
    }

    // ---------- WebSocket: استقبال تحديثات المهام ----------
    function connectWebSocket() {
        const protocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
        ws = new WebSocket(`${protocol}//${location.host}`);
        ws.onmessage = (event) => {
            try {
                const data = JSON.parse(event.data);
                if (data.type === 'task_update') {
                    addTimelineEvent(`${data.agent || 'Agent'} ${data.status} ${data.action || ''}`, data.status === 'failed' ? 'error' : 'info');
                    // تحديث حالة المهمة في الخطة الحالية
                    if (data.taskId) {
                        updateTaskStatusInPlan(data.taskId, data.status, data.result);
                    }
                    if (data.action === 'run_dev' && data.status === 'completed') {
                        const iframe = document.getElementById('livePreviewFrame');
                        if (iframe) iframe.src = 'http://localhost:3000';
                        document.getElementById('previewStatusText').innerText = 'Online';
                    }
                    refreshAll();
                }
                if (data.type === 'plan_update') {
                    addTimelineEvent(`📋 New plan: ${data.goal}`, 'info');
                    // يمكن تحديث الخطة إذا أردنا
                }
            } catch(e) {}
        };
        ws.onclose = () => setTimeout(connectWebSocket, 3000);
    }

    // ---------- Live Preview & Dev Server ----------
    async function checkPreviewStatus() {
        const iframe = document.getElementById('livePreviewFrame');
        iframe.src = 'http://localhost:3000';
        const timeout = setTimeout(() => {
            if (!iframe.src || iframe.src === 'about:blank') {
                document.getElementById('previewIndicator').className = 'inline-block w-2 h-2 bg-red-500 rounded-full';
                document.getElementById('previewStatusText').innerText = 'Offline - click Start Dev Server';
            }
        }, 3000);
        iframe.onload = () => {
            clearTimeout(timeout);
            document.getElementById('previewIndicator').className = 'inline-block w-2 h-2 bg-green-500 rounded-full';
            document.getElementById('previewStatusText').innerText = 'Online (localhost:3000)';
        };
        iframe.onerror = () => {
            clearTimeout(timeout);
            document.getElementById('previewIndicator').className = 'inline-block w-2 h-2 bg-red-500 rounded-full';
            document.getElementById('previewStatusText').innerText = 'Offline - click Start Dev Server';
            iframe.src = 'about:blank';
        };
    }

    async function startDevServer() {
        addTimelineEvent('Starting dev server...', 'info');
        try {
            const res = await fetch('/api/run-dev', { method: 'POST', headers: { Authorization: `Bearer ${token}` } });
            const data = await res.json();
            if (data.running || data.started) {
                addTimelineEvent('Dev server started or already running', 'success');
                setTimeout(() => {
                    const iframe = document.getElementById('livePreviewFrame');
                    if (iframe) iframe.src = 'http://localhost:3000';
                    document.getElementById('previewStatusText').innerText = 'Online';
                }, 3000);
            } else {
                addTimelineEvent('Failed to start dev server', 'error');
            }
        } catch(err) {
            addTimelineEvent(`Error: ${err.message}`, 'error');
        }
    }

    function reloadPreview() { checkPreviewStatus(); addTimelineEvent('Preview refreshed', 'info'); }

    // ---------- Refresh All ----------
    async function refreshAll() {
        await renderSidebarProjects();
        await renderHeroAndKPIs();
        await renderAgentsMetrics();
        await renderWorkflowPipeline();
        await renderStructuredArchitecture();
    }

    // ---------- User & Logout ----------
    async function loadUser() {
        try {
            const user = await fetch('/api/user/profile', { headers: { Authorization: `Bearer ${token}` } }).then(r=>r.json());
            document.getElementById('usernameDisplay').innerText = user.username || 'Developer';
        } catch(e) {}
    }

    // ---------- Event Listeners ----------
    document.getElementById('logoutBtn').onclick = () => { localStorage.removeItem('token'); window.location.href = '/user.html'; };
    document.getElementById('newProjectBtn').onclick = async () => {
        const name = prompt('Project name:');
        const path = prompt('Absolute path:');
        if (name && path) {
            await fetch('/api/projects', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                body: JSON.stringify({ name, path })
            });
            refreshAll();
        }
    };
    document.getElementById('newScratchProjectBtn').onclick = async () => {
        const projectName = prompt('Enter new project name (letters, numbers, hyphens):', 'my-jaola-app');
        if (!projectName) return;
        if (!/^[a-z0-9-]+$/i.test(projectName)) {
            alert('Invalid project name. Use only letters, numbers, and hyphens.');
            return;
        }
        try {
            const res = await fetch('/api/projects/init', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                body: JSON.stringify({ projectName })
            });
            const data = await res.json();
            if (res.ok) {
                alert(`✅ Project "${data.project.name}" created successfully.\nPath: ${data.project.path}\nIt is now active.`);
                refreshAll();
            } else {
                alert(`❌ Failed: ${data.error}`);
            }
        } catch (err) {
            alert(`❌ Error: ${err.message}`);
        }
    };
    document.getElementById('executeMissionBtn').onclick = () => {
        const input = document.getElementById('commandInput');
        sendMission(input.value);
        input.value = '';
    };
    document.getElementById('commandInput').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') sendMission(e.target.value);
    });
    document.getElementById('reloadPreviewBtn').onclick = reloadPreview;
    document.getElementById('startDevServerBtn').onclick = startDevServer;

    // Initialization
    loadUser();
    refreshAll();
    connectWebSocket();
    checkPreviewStatus();
    setInterval(refreshAll, 10000);
    setInterval(checkPreviewStatus, 15000);
</script>
</body>
</html>

